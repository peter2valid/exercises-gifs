R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Payment (optional)
PAYSTACK_SECRET_KEY=

# Observability (optional)
NEXT_PUBLIC_SENTRY_DSN=
